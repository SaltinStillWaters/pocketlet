# Stellar testnet configuration
NEXT_PUBLIC_STELLAR_RPC_URL=https://soroban-testnet.stellar.org
NEXT_PUBLIC_STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
NEXT_PUBLIC_STELLAR_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"

# Optional: override the default Circle testnet USDC contract address.
# Defaults to the official Circle testnet USDC SAC.
NEXT_PUBLIC_USDC_CONTRACT_ID=CBIELTK6YBZJU5UP2WWQEUCYKLPU6AUNZ2BQ4WWFEIE3USCIHMXQDAMA

# Platform deployer account. If not set, a new testnet account is generated
# and funded automatically. In production this must be set and kept secret.
PLATFORM_SECRET_KEY=

# Optional: DEX contract used by the swap endpoint (server-side only).
# If omitted on testnet, the app will auto-deploy the bundled mock_dex.wasm once.
DEX_CONTRACT_ID=

# Recovery waiting period in milliseconds. Defaults to 24 hours.
# Set to 60000 for quick manual testnet testing.
RECOVERY_WAITING_PERIOD_MS=86400000

# WebAuthn RP settings
WEBAUTHN_RP_NAME=Pocketlet
WEBAUTHN_RP_ID=localhost
WEBAUTHN_ORIGIN=http://localhost:3000

# Session cookie signing secret (change in production)
SESSION_SECRET=change-me-in-production
